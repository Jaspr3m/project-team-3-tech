<!-- // --- setup profile --- -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Setup Profile</title>
    <link rel="stylesheet" href="/static/css/profile.css" />
    <link rel="stylesheet" href="/static/css/header.css" />
    <link rel="stylesheet" href="/static/css/footer.css" />
  </head>
  <body>
    <header><%- include('partials/header') %></header>
    <main class="profile-container">
      <h1>Complete Your Profile</h1>
      <% if (typeof error !== 'undefined' && error) { %>
      <div style="color: red; margin-bottom: 1em"><%= error %></div>
      <% } %>
      <form action="/setup-profile" method="POST" enctype="multipart/form-data">
        <label>Profile picture:</label>
        <input type="file" name="photo" required />

        <label>Full name</label>
        <div class="side-by-side">
          <input
            placeholder="First name..."
            type="text"
            name="firstName"
            required
          />
          <input
            placeholder="Last name..."
            type="text"
            name="lastName"
            required
          />
        </div>

        <label>Gender: </label>
        <select name="gender" required>
          <option value="">Select gender</option>
          <option value="Male">Male</option>
          <option value="Female">Female</option>
          <option value="Other">Other</option>
        </select>

        <label>Date of Birth:</label>
        <input
          type="date"
          name="dob"
          required
          max="<%= new Date(Date.now() - 568025136000).toISOString().split('T')[0] %>"
        />

        <label>Vibe:</label>
        <select name="vibe" required>
          <option value="">Select vibe</option>
          <option value="Chill">Chill</option>
          <option value="Adventurous">Adventurous</option>
          <option value="Artsy">Artsy</option>
          <option value="Partyganger">Partyganger</option>
          <option value="Mindful">Mindful</option>
          <option value="Foodie">Foodie</option>
          <option value="Explorer">Explorer</option>
          <option value="Sporty">Sporty</option>
        </select>

        <label>Preferred Gender: </label>
        <select name="preferredGender" required>
          <option value="">Select Gender</option>
          <option value="Male">Male</option>
          <option value="Female">Female</option>
          <option value="Other">Other</option>
        </select>

        <label>Favorite Food and Drink</label>
        <div class="side-by-side">
          <select name="favoriteFood" placeholder="food" required>
            <option value="Sushi">Sushi</option>
            <option value="Tacos">Tacos</option>
            <option value="Spaghetti">Spaghetti Carbonara</option>
            <option value="Falafel">Falafel</option>
            <option value="Butter Chicken">Butter Chicken</option>
            <option value="Caesar Salad">Caesar Salad</option>
            <option value="Ramen">Ramen</option>
            <option value="Grilled Salmon">Grilled Salmon</option>
          </select>
          <select name="favoriteDrink" placeholder="drink" required>
            <option value="Iced Coffee">Iced Coffee</option>
            <option value="Green Tea">Green Tea</option>
            <option value="Mango Smoothie">Mango Smoothie</option>
            <option value="Sparkling Water">Sparkling Water</option>
            <option value="Mojito">Mojito</option>
            <option value="Hot Chocolate">Hot Chocolate</option>
            <option value="Fresh Lemonade">Fresh Lemonade</option>
            <option value="Chai Latte">Chai Latte</option>
          </select>
        </div>
        <button type="submit">Save & Continue</button>
      </form>
    </main>
    <!-- question here -->
    <footer><%- include('partials/footer', { userId: userId }) %></footer>
    <!-- ///////////// -->
  </body>
</html>
